{
  "name": "sounddome",
  "version": "0.8.6",
  "description": "SoundDome - Desktop soundboard with audio routing",
  "author": {
    "name": "Stefano Domenghini",
    "email": "74007706+DomenghiniStefano@users.noreply.github.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "dist": "electron-vite build && electron-builder",
    "release": "node scripts/release.js",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.sounddome.app",
    "productName": "SoundDome",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "SoundDome-Setup-${version}.${ext}",
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": true,
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "AudioVideo",
      "icon": "assets/icons/icon.png",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "DomenghiniStefano",
      "repo": "SoundDome",
      "releaseType": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**",
      "node_modules/node-hid/**",
      "node_modules/sharp/**",
      "node_modules/koffi/**"
    ],
    "npmRebuild": false
  },
  "dependencies": {
    "@types/node-hid": "^1.3.4",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "colorjs.io": "^0.6.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "koffi": "^2.15.1",
    "lodash": "^4.17.23",
    "node-hid": "^3.3.0",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "sortablejs": "^1.15.7",
    "sortablejs-vue3": "^1.3.0",
    "uiohook-napi": "^1.5.4",
    "unicode-emoji-json": "^0.8.0",
    "vue": "^3.5.29",
    "vue-accessible-color-picker": "^6.0.0",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "wavesurfer.js": "^7.12.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/lodash": "^4.17.24",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DomenghiniStefano/SoundDome.git"
  },
  "license": "MIT"
}
