{
  "name": "mini-soundboard",
  "version": "0.1.0",
  "description": "SoundDome - Desktop soundboard with audio routing",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "dist": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.sounddome.app",
    "productName": "SoundDome",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "asar": true
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
